# Fork - environment variables
# The app works WITHOUT these (typed input + bundled 2025 data + templated verdict).
# Add them to unlock the live path: voice/AI parsing, live rent, AI narration.

# Groq API key - powers /api/parse, /api/narrate, /api/whatif (Llama via Groq)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# RentCast API key - powers /api/rent live market rent (US). Free tier: 50 calls/mo.
# Get one at https://app.rentcast.io/app/api
RENTCAST_API_KEY=
